# PostgreSQL — relational data (flights, hotels, bookings, wallet, promos)
DATABASE_URL=postgresql://booking_user:booking_pass@localhost:5432/booking

# MongoDB — document data (chat history, price alerts, activity logs, preferences)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=booking

# Redis — search cache (flights/hotels), confirmations log
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Kafka — booking events (topic: booking.events)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BOOKING_TOPIC=booking.events

# RabbitMQ — confirmation queue (booking.confirmation → Redis log)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_CONFIRMATIONS=booking.confirmation

PORT=4000
